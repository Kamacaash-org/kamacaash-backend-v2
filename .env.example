# App
NODE_ENV=development
PORT=5216
DEFAULT_STAFF_PASSWORD=change-me

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/database_name
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_NAME=app_db
DB_SSL=false

# JWT
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# PostGIS
POSTGIS_ENABLED=true
DEFAULT_SEARCH_RADIUS=10

# Payment Providers
EVC_PLUS_API_KEY=
JEEB_API_KEY=
E_DAHAB_API_KEY=

# Notifications
SMS_PROVIDER=
SMS_API_KEY=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=

# S3
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=

# Firebase Cloud Messaging
# Option 1: set the three values below from your Firebase service account
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_LINE_1\nYOUR_PRIVATE_KEY_LINE_2\n-----END PRIVATE KEY-----\n"

# Option 2: use the full service account JSON as a single-line escaped string instead
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional: comma-separated device tokens for test notifications
FCM_TEST_DEVICE_TOKENS=

# WAAFI Push Payments
WAAFI_ENABLED=false
WAAFI_BASE_URL=https://api.waafipay.net/asm
WAAFI_CHANNEL_NAME=WEB
WAAFI_SERVICE_NAME=API_PURCHASE
WAAFI_MERCHANT_UID=
WAAFI_API_USER_ID=
WAAFI_API_KEY=
WAAFI_PAYMENT_METHOD=mwallet_account
WAAFI_CURRENCY=USD
WAAFI_TIMEOUT_MS=30000

# Loyalty Rewards
LOYALTY_ENABLED=true
LOYALTY_POINTS_PER_DOLLAR=10
LOYALTY_MIN_PAYMENT=1
LOYALTY_MAX_POINTS_PER_TX=1000

# Review Reminder Queue
ORDER_HOLD_QUEUE_ENABLED=true
ORDER_HOLD_QUEUE_NAME=order-holds
ORDER_HOLD_QUEUE_ATTEMPTS=3
ORDER_HOLD_QUEUE_BACKOFF_MS=60000
REVIEW_REMINDER_QUEUE_ENABLED=false
REVIEW_REMINDER_QUEUE_NAME=review-reminders
REVIEW_REMINDER_DELAY_MS=1200000
REVIEW_REMINDER_ATTEMPTS=3
REVIEW_REMINDER_BACKOFF_MS=60000
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
